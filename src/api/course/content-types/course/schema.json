{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 255,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "programming",
        "design",
        "business",
        "marketing",
        "management",
        "soft-skills",
        "other"
      ]
    },
    "level": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "duration": {
      "type": "integer",
      "required": true
    },
    "instructor": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    }
  }
}
